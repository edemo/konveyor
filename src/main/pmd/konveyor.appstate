               </property>
               <property property-name="message">
                  <value type="java.lang.String"
                         value="Services have @Autowired fields and public apply method"/>
               </property>
               <property property-name="clazz">
                  <value type="java.lang.Class&lt;?&gt;"
                         value="net.sourceforge.pmd.lang.rule.xpath.XPathRule"/>
               </property>
               <property property-name="since">
                  <value type="java.lang.String" value=""/>
               </property>
