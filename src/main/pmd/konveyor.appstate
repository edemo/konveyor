                        <property property-name="source">
                           <value type="java.lang.String"
                                  value="@Service&#xA;public class DoSomethingService {&#xA;&#xA;    @Autowired&#xA;    DoTheOtherThingService doTheOtherThing;&#xA;&#xA;    @Autowired&#xA;    DoTheThirdThingService third;&#xA;&#xA;}"/>
