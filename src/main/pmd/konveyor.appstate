               <property property-name="xpathExpression">
                  <value type="java.lang.String"
                         value="//ClassDeclaration[./ModifierList/Annotation[@SimpleName=&#34;Service&#34;]]//(&#xA; FieldDeclaration[&#xA;    not(&#xA;        ./VariableDeclarator/VariableId/@Name =&#xA;            lower-case(substring(./ClassType/@SimpleName,1,1))||&#xA;            substring-before(substring(./ClassType/@SimpleName,2),&#34;Service&#34;) or&#xA;        ./VariableDeclarator/VariableId/@Name =&#xA;            lower-case(substring(./ClassType/@SimpleName,1,1))||&#xA;            substring-before(substring(./ClassType/@SimpleName,2),&#34;Repository&#34;)||&#34;Repository&#34;&#xA;    ) or&#xA;    not(./ModifierList/Annotation/@SimpleName = &#34;Autowired&#34;) or&#xA;    not(@EffectiveVisibility = &#34;package&#34;)&#xA; ]|&#xA; //MethodDeclaration[&#xA;    @EffectiveVisibility = &#34;public&#34; and not(@Name=&#34;apply&#34;)&#xA; ]|&#xA; //ClassDeclaration[./@EffectiveVisibility != &#34;public&#34;]&#xA;)&#xA;"/>
               </property>
               <property property-name="description">
                  <value type="java.lang.String"
                         value="A service is a class with a @Service annotation&#xA;&#xA;The dependencies of the service are described in fields with @Autowired annotations&#xA;&#xA;No other fields are allowed&#xA;&#xA;The functionality is exposed in public methods with name apply.&#xA;&#xA;The reason that not only one such methods are applied is to allow with trivial type conversions and such. All methods should expose the same functionality without adding any substantial logic.&#xA;&#xA;"/>
               </property>
               <property property-name="language">
                  <value type="net.sourceforge.pmd.lang.Language" value="java"/>
               </property>
               <property property-name="externalInfoUrl">
                  <value type="java.lang.String" value=""/>
               </property>
               <property property-name="priority">
